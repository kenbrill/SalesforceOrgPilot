{
  "manifest_version": 3,
  "name": "Salesforce Quick Navigator",
  "version": "1.57",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Open Salesforce Quick Navigator"
    },
    "group-sf-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Group all Salesforce tabs by environment"
    },
    "consolidate-sf-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+T"
      },
      "description": "Pull all Salesforce tabs into current window and group"
    }
  },
  "omnibox": {
    "keyword": "sf"
  },
  "permissions": ["storage", "tabs", "history", "tabGroups"],
  "action": {
    "default_title": "Salesforce Quick Navigator",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "salesforce-quick-navigator@kenbrill",
      "strict_min_version": "139.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.salesforce.com/*", "*://*.lightning.force.com/*", "*://*.salesforce-setup.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
